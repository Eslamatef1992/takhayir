# Server
NODE_ENV=development
PORT=4000
API_URL=https://back.takhayir.com
CLIENT_STOREFRONT_URL=https://www.takhayir.com
CLIENT_ADMIN_URL=https://admin.takhayir.com
CLIENT_VENDOR_URL=https://vendor.takhayir.com

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=takhayir
DB_USER=root
DB_PASSWORD=change_me
DB_DIALECT=mysql

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_too_to_a_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Email (used for "forgot password" reset links). Any SMTP provider works -
# e.g. a Gmail app password, SendGrid, Mailgun, Amazon SES SMTP, etc.
# If left blank, reset emails are logged to the server console instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Takhayir <no-reply@takhayir.com>

# --- Payment integrations (fill in later, see /docs/PAYMENTS.md) ---
# Direct gateway: Tap Payments (also used for Deema BNPL)
TAP_API_BASE_URL=https://api.tap.company/v2
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
TAP_WEBHOOK_SECRET=

# Taly BNPL (Kuwait)
TALY_API_BASE_URL=https://api.taly.io
TALY_MERCHANT_USERNAME=
TALY_MERCHANT_PASSWORD=
TALY_WEBHOOK_SECRET=
